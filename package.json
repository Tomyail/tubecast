{
  "name": "mobile",
  "version": "1.1.0",
  "packageManager": "pnpm@10.28.1",
  "main": "index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tomyail/tubecast.git"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "release:ios": "expo prebuild --platform ios --no-install && expo run:ios --device --configuration Release",
    "release:version": "node scripts/release.mjs version",
    "release:archive": "node scripts/release.mjs archive",
    "release:publish": "node scripts/release.mjs publish",
    "release:rebuild": "node scripts/release.mjs rebuild",
    "release:sync-ios": "node scripts/release.mjs sync-ios",
    "release:changelog": "node scripts/release.mjs changelog",
    "release:testflight": "node scripts/release.mjs testflight",
    "release:testflight-bump": "node scripts/release.mjs testflight-bump",
    "release:testflight-prepare": "node scripts/release.mjs testflight-prepare",
    "release:testflight-build": "node scripts/release.mjs testflight-build",
    "release:testflight-upload": "node scripts/release.mjs testflight-upload",
    "release:testflight-changelog": "node scripts/release.mjs testflight-changelog",
    "release:testflight-distribute": "node scripts/release.mjs testflight-distribute",
    "release:testflight-tag": "node scripts/release.mjs testflight-tag",
    "store:metadata": "mise exec -- bundle exec fastlane metadata_push",
    "store:screenshots": "mise exec -- bundle exec fastlane screenshots_push",
    "store:assets": "mise exec -- bundle exec fastlane store_assets_push",
    "store:download-metadata": "mise exec -- bundle exec fastlane deliver download_metadata --app_identifier com.tomyail.tubecast --metadata_path ./fastlane/metadata",
    "store:download-screenshots": "mise exec -- bundle exec fastlane deliver download_screenshots --app_identifier com.tomyail.tubecast --screenshots_path ./fastlane/screenshots --use_live_version true",
    "test": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/dom-webview": "~56.0.5",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.18.1",
    "expo": "~56.0.12",
    "expo-audio": "~56.0.12",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-file-system": "^56.0.8",
    "expo-image": "^56.0.11",
    "expo-localization": "~56.0.6",
    "expo-modules-core": "56.0.17",
    "expo-secure-store": "^56.0.4",
    "expo-sharing": "^56.0.18",
    "expo-status-bar": "~56.0.4",
    "i18next": "^25.8.0",
    "react": "19.2.3",
    "react-i18next": "^16.5.0",
    "react-native": "0.85.3",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~56.0.15",
    "commit-and-tag-version": "^12.7.3",
    "husky": "^9.1.7",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  },
  "private": false
}
